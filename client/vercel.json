{
  "version": 2,
  "rewrites": [
    {
      "source": "/proxy/auth/:path*",
      "destination": "https://national-emergency-platform-auth-api.onrender.com/:path*"
    },
    {
      "source": "/proxy/incident/:path*",
      "destination": "https://national-emergency-platform-incident.onrender.com/:path*"
    },
    {
      "source": "/proxy/dispatch/:path*",
      "destination": "https://national-emergency-platform-dispatch-api.onrender.com/:path*"
    },
    {
      "source": "/proxy/analytics/:path*",
      "destination": "https://national-emergency-platform-analytics.onrender.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
