{
  "public": ".",
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "**/*",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/proxy/**", "destination": "/index.html" }
  ],
  "redirects": [],
  "unlisted": ["node_modules"]
}
